# =============================================================================
# AI WhatsApp Assistant - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# =============================================================================
# GENERAL
# =============================================================================
APP_NAME=ai-whatsapp-assistant
APP_VERSION=1.0.0
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://your-domain.com
APP_SECRET=generate-a-32-char-random-secret-key-here
APP_OWNER_EMAIL=admin@your-domain.com
APP_OWNER_PASSWORD=change-me-at-first-login

# =============================================================================
# DATABASE (PostgreSQL + pgvector)
# =============================================================================
POSTGRES_HOST=your-postgres-host.com
POSTGRES_PORT=5432
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=aiwa_production
DATABASE_URL=postgresql+asyncpg://your-db-user:your-db-password@your-postgres-host.com:5432/aiwa_production

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@your-redis-host.com:6379/0

# =============================================================================
# JWT AUTHENTICATION (min 32 chars)
# =============================================================================
JWT_SECRET=generate-a-32-char-random-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# =============================================================================
# ENCRYPTION (Fernet - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# =============================================================================
ENCRYPTION_KEY=your-fernet-key-here

# =============================================================================
# AI PROVIDER (choose one: gemini, openai, anthropic, openrouter, minimax, ollama)
# =============================================================================
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# MiniMax
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=MiniMax-Text-01

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# =============================================================================
# EMBEDDINGS
# =============================================================================
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# =============================================================================
# STORAGE
# =============================================================================
STORAGE_BACKEND=local
STORAGE_PATH=/data/media
# S3 Options (if using S3)
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_BUCKET=your-bucket
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# =============================================================================
# WHATSAPP BRIDGE
# =============================================================================
BRIDGE_URL=http://whatsapp-bridge:3001
BRIDGE_WEBHOOK_SECRET=generate-a-random-webhook-secret

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# =============================================================================
# SMTP (Email)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=AI Assistant <noreply@your-domain.com>
